#!/usr/bin/env python3
"""
智能命令助手 - ask
功能：记住历史执行记录，基于上下文回答问题并执行命令
"""

import subprocess
import sys
import json
import os
from datetime import datetime
from pathlib import Path

# 配置
HISTORY_FILE = Path.home() / ".ask_history.json"
SETTINGS_FILE = Path.home() / ".ask_setting.json"
MAX_HISTORY = 50  # 保留最近50条记录


DEFAULT_SETTINGS = {
    "base_url": "https://cloud.infini-ai.com/maas/v1",
    "api_key": "你的API密钥",
    "model": "kimi-k2.5"
}


def load_settings() -> dict:
    """从 ~/.ask_setting.json 加载配置，如果不存在则创建"""
    # 如果配置文件不存在，创建它
    if not SETTINGS_FILE.exists():
        SETTINGS_FILE.write_text(json.dumps(DEFAULT_SETTINGS, indent=2, ensure_ascii=False))
        print("=" * 50)
        print("首次运行，请先配置 ~/.ask_setting.json")
        print(f"配置文件位置: {SETTINGS_FILE}")
        print("\n配置示例:")
        print(json.dumps(DEFAULT_SETTINGS, indent=2, ensure_ascii=False))
        print("=" * 50)
        return None

    try:
        settings = json.loads(SETTINGS_FILE.read_text())
        # 检查是否配置好了
        if not settings.get("api_key") or settings.get("api_key") == "你的API密钥":
            print("请先配置 ~/.ask_setting.json 中的 api_key")
            return None
        return settings
    except:
        print("配置文件格式错误")
        return None

class AskAssistant:
    def __init__(self):
        self.history = self._load_history()

    def _load_history(self) -> list:
        """加载历史记录 - 直接读取 shell 历史"""
        # 读取 .bash_history 获取最近 10 条
        bash_history = Path.home() / ".bash_history"
        records = []

        if bash_history.exists():
            lines = bash_history.read_text().strip().split("\n")
            # 取最近 10 条（跳过空行）
            recent = [l.strip() for l in lines[-10:] if l.strip()]

            for cmd in recent:
                records.append({
                    "time": "",
                    "command": cmd,
                    "output": "",
                    "success": True,  # 从 shell 历史无法判断成功与否，默认成功
                    "error": ""
                })

        return records

    def _save_history(self):
        """保存历史记录"""
        HISTORY_FILE.write_text(json.dumps(self.history[-MAX_HISTORY:], indent=2, ensure_ascii=False))

    def _add_record(self, command: str, output: str, success: bool, error: str = ""):
        """添加执行记录"""
        record = {
            "time": datetime.now().isoformat(),
            "command": command,
            "output": output[:2000],  # 限制输出长度
            "success": success,
            "error": error[:500] if error else ""
        }
        self.history.append(record)
        self._save_history()

    def _get_context(self) -> str:
        """获取上下文信息（最近5条记录）"""
        if not self.history:
            return "暂无历史记录"

        recent = self.history[-5:]
        lines = []
        for r in recent:
            status = "✓" if r["success"] else "✗"
            lines.append(f"[{status}] {r['command']}")
            if not r["success"] and r["error"]:
                lines.append(f"    错误: {r['error'][:200]}")
        return "\n".join(lines)

    def _detect_shell(self) -> str:
        """检测当前 shell 环境"""
        # 优先检查 Windows 环境
        if os.name == 'nt' or os.environ.get('WINDIR'):
            # 检查是否是 PowerShell
            if os.environ.get('PSModulePath') or os.environ.get('PSExecutionPolicyPreference'):
                return "PowerShell"
            return "CMD"

        shell = os.environ.get("SHELL", "")
        if "powershell" in shell.lower() or os.environ.get("PSModulePath"):
            return "PowerShell"
        elif "zsh" in shell.lower():
            return "zsh"
        elif "fish" in shell.lower():
            return "fish"
        elif "bash" in shell.lower():
            return "Bash"
        elif "cmd" in shell.lower():
            return "CMD"
        else:
            return shell if shell else "Bash"

    def _build_prompt(self, question: str) -> str:
        """构建 AI 提示词"""
        context = self._get_context()
        shell = self._detect_shell()

        return f"""你是一个{shell}命令行助手。

## 用户问题
{question}

## 历史执行记录（参考）
{context}

## 当前环境
Shell: {shell}

## 输出要求（严格遵守）
只返回一个shell命令，不要任何解释。如果不需要命令，返回：NO_COMMAND:原因

关键规则：
- 根据当前Shell类型返回对应命令
- 只返回纯命令，如 "ls -la" 或 "apt install docker"
- 不要返回包含中文的句子
- 不要返回解释性文字
- 如果只是聊天，返回NO_COMMAND:原因

命令："""

    def ask_ai(self, question: str) -> str:
        """调用 AI API 获取答案"""
        import requests

        prompt = self._build_prompt(question)

        # 加载配置（优先级：环境变量 > setting.json）
        settings = load_settings()
        if settings is None:
            return "NO_COMMAND: 请先配置 ~/.ask_setting.json"

        base_url = os.environ.get("ANTHROPIC_BASE_URL", "").rstrip("/") or settings.get("base_url", "")
        api_key = os.environ.get("ANTHROPIC_AUTH_TOKEN") or os.environ.get("ANTHROPIC_API_KEY") or settings.get("api_key", "")
        model = os.environ.get("ANTHROPIC_MODEL") or settings.get("model", "kimi-k2.5")

        # 方式1: 使用 OpenAI 兼容格式 (无问芯穹/千帆等)
        if base_url and api_key:
            try:
                # 检测格式：chat/completions (OpenAI) 或 messages (Anthropic)
                if "/chat/completions" in base_url or "/maas/" in base_url:
                    url = f"{base_url}/chat/completions"
                else:
                    url = f"{base_url}/v1/messages"

                headers = {
                    "Authorization": f"Bearer {api_key}",
                    "content-type": "application/json"
                }
                data = {
                    "model": model,
                    "max_tokens": 500,
                    "messages": [{"role": "user", "content": prompt}]
                }
                resp = requests.post(url, headers=headers, json=data, timeout=60)
                resp.raise_for_status()
                result = resp.json()

                # 解析 OpenAI 格式响应
                if "choices" in result:
                    msg = result["choices"][0]["message"]

                    # 优先使用 content，如果没有就用 reasoning_content
                    content = msg.get("content")
                    if not content:
                        # 尝试从 reasoning 中提取答案
                        content = msg.get("reasoning_content", "")

                    if not content:
                        return self._local_fallback(question)

                    content = content.strip()

                    # 检查是否是有效命令（不包含中文，换行少）
                    has_chinese = any('\u4e00' <= c <= '\u9fff' for c in content)
                    lines = [l for l in content.split("\n") if l.strip()]

                    if has_chinese or len(lines) > 1:
                        return self._local_fallback(question)

                    return content

                # 解析 Anthropic 格式响应
                content = result.get("content", [])
                if content:
                    # 可能包含 text 或 thinking+text
                    for item in content:
                        if item.get("type") == "text":
                            return item.get("text", "").strip()
                    # 如果没有 text 类型，取第一个
                    return content[0].get("text", "").strip()
            except Exception as e:
                print(f"API 调用失败: {e}")

        # 方式2: 使用 openai 兼容 API
        openai_key = os.environ.get("OPENAI_API_KEY")
        if openai_key:
            try:
                import openai
                client = openai.OpenAI(api_key=openai_key)
                response = client.chat.completions.create(
                    model="gpt-4",
                    messages=[{"role": "user", "content": prompt}],
                    max_tokens=500
                )
                return response.choices[0].message.content.strip()
            except Exception as e:
                print(f"OpenAI API 调用失败: {e}")

        # 方式3: 回退到本地规则匹配
        return self._local_fallback(question)

    def _local_fallback(self, question: str) -> str:
        """无 AI API 时的本地回退"""
        # 检查最近的错误
        if self.history and not self.history[-1]["success"]:
            last_error = self.history[-1].get("error", "")
            if "command not found" in last_error.lower():
                return f"apt update && apt install -y {self.history[-1]['command'].split()[0]}"
            if "permission denied" in last_error.lower():
                return f"sudo {self.history[-1]['command']}"

        # 简单关键词匹配
        q = question.lower()
        if "docker" in q and "安装" in q:
            return "curl -fsSL https://get.docker.com | sh"
        if "git" in q and "安装" in q:
            return "apt update && apt install -y git"

        return "NO_COMMAND: 需要配置 AI API 才能智能回答"

    def execute(self, command: str) -> tuple[bool, str, str]:
        """执行命令并返回结果"""
        try:
            result = subprocess.run(
                command,
                shell=True,
                capture_output=True,
                text=True,
                timeout=300
            )

            # 判断成功：returncode == 0 且 stderr 为空
            stderr = result.stderr
            success = result.returncode == 0 and not stderr.strip()

            output = result.stdout or result.stderr

            # 如果有 stderr 但 returncode 是 0，可能是部分成功或警告
            if stderr.strip() and result.returncode == 0:
                error = stderr  # 把 stderr 当作警告而不是错误
            else:
                error = result.stderr if not success else ""

            return success, output, error
        except subprocess.TimeoutExpired:
            return False, "", "命令执行超时"
        except Exception as e:
            return False, "", str(e)

    def _parse_commands(self, answer: str) -> list:
        """解析多行命令"""
        if not answer.strip():
            return []

        # 按换行分割
        lines = answer.strip().split("\n")
        commands = []

        for line in lines:
            line = line.strip()
            # 跳过空行和注释
            if not line or line.startswith("#"):
                continue
            # 移除行首的编号如 "1." 或 "-"
            import re
            line = re.sub(r'^[\d]+\.\s*', '', line)
            line = re.sub(r'^-\s*', '', line)
            commands.append(line)

        # 如果只有一个命令，可能用 && 或 ; 分隔
        if len(commands) == 1:
            cmd = commands[0]
            if " && " in cmd:
                commands = [c.strip() for c in cmd.split(" && ")]

        return commands

    def confirm(self, command: str) -> bool:
        """确认是否执行"""
        print(f"\n{'='*50}")
        print(f"将执行命令: {command}")
        print(f"{'='*50}")
        ans = input("确认执行? [回车执行/n退出/e编辑]: ").strip().lower()

        # 回车或空输入视为确认
        if ans == '' or ans == 'y' or ans == 'yes':
            return True

        if ans == 'e':
            # 允许用户编辑命令
            new_cmd = input(f"编辑命令 [{command}]: ").strip()
            return self.confirm(new_cmd if new_cmd else command)

        # n、no 或其他输入视为取消
        return False

    def run(self, question: str, auto_confirm: bool = False):
        """主流程"""
        # 获取答案
        answer = self.ask_ai(question)

        if answer.startswith("NO_COMMAND:"):
            print(f"\n{answer[12:]}")
            return

        # 解析多行命令
        commands = self._parse_commands(answer)
        if not commands:
            print("无法解析命令")
            return

        # 显示待执行的命令
        print(f"\n将执行 {len(commands)} 个步骤:")
        for i, cmd in enumerate(commands, 1):
            print(f"  {i}. {cmd}")
        print()

        # 确认执行
        if auto_confirm or self.confirm(answer):
            print("执行中...\n")
            all_success = True

            # 依次执行每个命令
            for i, cmd in enumerate(commands, 1):
                print(f"=== 步骤 {i}/{len(commands)} ===")
                print(f"$ {cmd}")
                success, output, error = self.execute(cmd)

                print(f"结果: {'✓ 成功' if success else '✗ 失败'}")
                if output:
                    print(output[:500])
                if error:
                    print(f"错误: {error[:200]}")

                # 记录结果
                self._add_record(cmd, output, success, error)

                # 如果失败，询问是否继续
                if not success:
                    print("\n命令执行失败，是否继续执行剩余命令? [y/N]")
                    ans = input("> ").strip().lower()
                    if ans not in ('y', 'yes'):
                        print("已停止")
                        break
                    all_success = False
                print()

            print(f"\n{'全部完成' if all_success else '已终止'}")
        else:
            print("已取消")

    def show_history(self, n: int = 10):
        """显示历史记录"""
        recent = self.history[-n:]
        print(f"\n最近 {len(recent)} 条执行记录:")
        print("-" * 60)
        for r in recent:
            status = "✓" if r["success"] else "✗"
            print(f"[{status}] {r['time'][:19]} | {r['command'][:50]}")


def main():
    assistant = AskAssistant()

    # 解析参数
    auto_confirm = False
    args = sys.argv[1:]

    if "-y" in args:
        auto_confirm = True
        args.remove("-y")

    if not args:
        print("用法: ask [-y] <问题>")
        print("      ask --history [数量]  # 查看历史")
        print("\n选项:")
        print("  -y    跳过确认，直接执行")
        print("\n示例:")
        print("  ask 如何安装docker?")
        print("  ask -y 如何安装git?  # 自动执行")
        print("  ask 上一个命令为什么失败?")
        sys.exit(1)

    if args[0] == "--history":
        n = int(args[1]) if len(args) > 1 else 10
        assistant.show_history(n)
        return

    question = " ".join(args)
    assistant.run(question, auto_confirm)


if __name__ == "__main__":
    main()
